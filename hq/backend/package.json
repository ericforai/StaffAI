{
  "name": "backend",
  "version": "1.0.1",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs');try{fs.rmSync('dist',{recursive:true});}catch(e){if(e&&e.code!=='ENOENT')throw e;}\" && tsc",
    "test": "npm run build && AGENCY_UNDER_NODE_TEST=1 AGENCY_TASK_TIMEOUT_MS=5000 node --test --test-concurrency=1 $(pwd)/dist/**/*.test.js",
    "start:web": "node dist/web-server.js",
    "start:mcp": "node dist/mcp-server.js",
    "dev:web": "ts-node src/web-server.ts",
    "dev:mcp": "ts-node src/mcp-server.ts",
    "generate:executions": "ts-node src/scripts/generate-execution-records.ts",
    "auto-fix": "node ../../.claude/scripts/fix.js run",
    "auto-fix:status": "node ../../.claude/scripts/fix.js status",
    "auto-fix:reset": "node ../../.claude/scripts/fix.js reset",
    "auto-fix:history": "node ../../.claude/scripts/fix.js history",
    "watch:fix": "node ../../.claude/scripts/watch-and-fix.js",
    "test:watch": "node ../../.claude/scripts/watch-and-fix.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bullmq": "^5.71.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.10.1",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
